#!/usr/bin/make -f

SRCDIR = ../../NexusMP/amd64-linux/src
SRCS   = main.c nexus_mp_amd64.c auth_amd64.c acl_amd64.c \
         compression_amd64.c config_amd64.c memory_amd64.c \
         network_amd64.c notifications_amd64.c protocol_amd64.c \
         quota_amd64.c search_amd64.c storage_amd64.c threading_amd64.c

%:
	dh $@

override_dh_auto_build:
	gcc -o $(SRCDIR)/nexus-mp $(addprefix $(SRCDIR)/,$(SRCS)) \
		-I$(SRCDIR) -lssl -lcrypto -lpthread

override_dh_auto_install:
	mkdir -p debian/nexus-mp-amd64/usr/bin
	cp $(SRCDIR)/nexus-mp debian/nexus-mp-amd64/usr/bin/

override_dh_auto_clean:
	rm -f $(SRCDIR)/nexus-mp
