#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_build:
	cd ../../NexusMP/termux32/src && $(MAKE) -f Makefile.termux32
	cd ../../NexusMTA/termux32/src && $(MAKE) -f Makefile.termux32 || true
	cd ../../NexusSMTP/termux32/src && $(MAKE) -f Makefile.termux32 || true
	cd ../../NexusRMC/termux32/src && $(MAKE) -f Makefile.termux32 || true

override_dh_auto_install:
	mkdir -p debian/tmp/usr/bin
	cp ../../NexusMP/termux32/src/nexus-mp debian/tmp/usr/bin/ || true
	cp ../../NexusMTA/termux32/src/nexus-mta debian/tmp/usr/bin/ || true
	cp ../../NexusSMTP/termux32/src/nexus-smtp debian/tmp/usr/bin/ || true
	cp ../../NexusRMC/termux32/src/nexus-rmc debian/tmp/usr/bin/ || true

override_dh_auto_clean:
	cd ../../NexusMP/termux32/src && $(MAKE) -f Makefile.termux32 clean || true
	cd ../../NexusMTA/termux32/src && $(MAKE) -f Makefile.termux32 clean || true
	cd ../../NexusSMTP/termux32/src && $(MAKE) -f Makefile.termux32 clean || true
	cd ../../NexusRMC/termux32/src && $(MAKE) -f Makefile.termux32 clean || true
