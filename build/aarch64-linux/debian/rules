#!/usr/bin/make -f

SRCDIR = ../../NexusMP/aarch64-linux/src
SRCS   = nexus_mp.c maildir.c auth.c auth_advanced.c storage_advanced.c \
         network_advanced.c search_advanced.c config_advanced.c \
         acl_advanced.c protocol_advanced.c memory_advanced.c \
         notifications_advanced.c compression_advanced.c threading_advanced.c

%:
	dh $@

override_dh_auto_build:
	gcc -o $(SRCDIR)/nexus-mp $(addprefix $(SRCDIR)/,$(SRCS)) \
		-I$(SRCDIR) -lssl -lcrypto -lpthread

override_dh_auto_install:
	mkdir -p debian/nexus-mp-aarch64/usr/bin
	cp $(SRCDIR)/nexus-mp debian/nexus-mp-aarch64/usr/bin/

override_dh_auto_clean:
	rm -f $(SRCDIR)/nexus-mp
