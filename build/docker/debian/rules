#!/usr/bin/make -f

SRCDIR = ../../NexusMP/docker/src

%:
	dh $@

override_dh_auto_build:
	gcc -o $(SRCDIR)/nexus-mp $(SRCDIR)/*.c \
		-I$(SRCDIR) -lssl -lcrypto -lpthread

override_dh_auto_install:
	mkdir -p debian/nexus-mp-docker/usr/bin
	cp $(SRCDIR)/nexus-mp debian/nexus-mp-docker/usr/bin/

override_dh_auto_clean:
	rm -f $(SRCDIR)/nexus-mp
