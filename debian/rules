#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_build:
	cd NexusMP/amd64-linux/src && $(MAKE) -f Makefile.amd64
	cd NexusMTA/amd64-linux/src && $(MAKE) -f Makefile.amd64 || true
	cd NexusSMP/amd64-linux/src && $(MAKE) -f Makefile.amd64 || true
	cd NexusRMC/amd64-linux/src && $(MAKE) -f Makefile.amd64 || true

override_dh_auto_install:
	mkdir -p debian/tmp/usr/bin
	mkdir -p debian/tmp/usr/lib
	mkdir -p debian/tmp/etc/nexus-mail
	
	cp NexusMP/amd64-linux/src/nexus-mp debian/tmp/usr/bin/ || true
	cp NexusMTA/amd64-linux/src/nexus-mta debian/tmp/usr/bin/ || true
	cp NexusSMP/amd64-linux/src/nexus-smp debian/tmp/usr/bin/ || true
	cp NexusRMC/amd64-linux/src/nexus-rmc debian/tmp/usr/bin/ || true

override_dh_auto_clean:
	cd NexusMP/amd64-linux/src && $(MAKE) -f Makefile.amd64 clean || true
	cd NexusMTA/amd64-linux/src && $(MAKE) -f Makefile.amd64 clean || true
	cd NexusSMP/amd64-linux/src && $(MAKE) -f Makefile.amd64 clean || true
	cd NexusRMC/amd64-linux/src && $(MAKE) -f Makefile.amd64 clean || true
